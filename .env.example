# 노션 연동 온라인 견적서 환경변수 예제 파일
# 이 파일을 .env.local로 복사한 후 실제 값을 입력하세요
# cp .env.example .env.local

# ============================================================
# 앱 설정
# ============================================================
NEXT_PUBLIC_APP_NAME="노션 연동 온라인 견적서"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================================
# 노션 API 설정
# 노션 개발자 페이지(https://www.notion.so/my-integrations)에서 발급
# ============================================================
NOTION_API_KEY="secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 노션 데이터베이스 ID (각 DB 페이지 URL에서 추출)
# URL 형식: https://notion.so/{workspace}/{database_id}?v=...
NOTION_INVOICES_DB_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NOTION_INVOICE_ITEMS_DB_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NOTION_ACCESS_TOKENS_DB_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================================
# 관리자 인증 설정
# ============================================================
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="your-secure-password"

# 세션 보안 키 (임의의 32자 이상 문자열)
SESSION_SECRET="your-very-secure-session-secret-key-minimum-32-chars"
